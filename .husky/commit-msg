#!/usr/bin/env sh

# Conventional commit message format
# Format: <type>(<scope>): <description>
# Types: feat, fix, docs, style, refactor, test, chore, perf, ci, build, revert, merge

# Regex for conventional commits
conventional_regex='^(feat|fix|docs|style|refactor|test|chore|perf|ci|build|revert|merge)(\(.+\))?: .{1,72}'

# Regex for Git merge commits
merge_regex='^Merge branch .* of .* into .*'
merge_regex2='^Merge branch .* of .*'

# Combined regex - either conventional or merge format
commit_regex="($conventional_regex|$merge_regex|$merge_regex2)"

if ! grep -qE "$commit_regex" "$1"; then
    echo "❌ Invalid commit message format."
    echo "✅ Please use either:"
    echo "   1. Conventional commit format: <type>(<scope>): <description>"
    echo "   2. Git's standard merge format: Merge branch '...' of ... into ..."
    echo ""
    echo "📝 Examples:"
    echo "   feat(contract): add merkle root anchoring to registry"
    echo "   fix(address-manager): resolve panic on empty username lookup"
    echo "   docs: add contributing guide for new contributors"
    echo "   refactor(zk): simplify poseidon hasher circuit inputs"
    echo "   Merge branch 'main' of https://github.com/Alien-Protocol/Alien-Gateway into feat/branch"
    echo ""
    echo "🔧 Types: feat, fix, docs, style, refactor, test, chore, perf, ci, build, revert, merge"
    exit 1
fi

echo "✅ Commit message format is valid!"
